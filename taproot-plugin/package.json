{
  "name": "taproot-mcp",
  "displayName": "taproot-mcp",
  "description": "Fleet-level MCP dashboard for SSH clusters: edit nodes.yaml and check taproot-mcp connectivity.",
  "version": "0.1.50",
  "publisher": "xiaoxiao27110",
  "license": "SEE LICENSE IN LICENSE",
  "preview": true,
  "pricing": "Free",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#111827",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/xiaoxiao27110/taproot.git",
    "directory": "taproot-plugin"
  },
  "bugs": {
    "url": "https://github.com/xiaoxiao27110/taproot/issues"
  },
  "homepage": "https://github.com/xiaoxiao27110/taproot#readme",
  "keywords": [
    "mcp",
    "ssh",
    "cluster",
    "fleet",
    "nodes.yaml",
    "taproot"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/src/extension.js",
  "extensionKind": [
    "workspace"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false,
      "description": "Taproot reads and writes its nodes.yaml file and runs taproot-mcp commands."
    },
    "virtualWorkspaces": {
      "supported": false,
      "description": "Taproot requires filesystem and process access for nodes.yaml and taproot-mcp."
    }
  },
  "activationEvents": [
    "onView:taproot.nodes",
    "onCommand:taproot.openDashboard",
    "onCommand:taproot.openConfig",
    "onCommand:taproot.testConnections",
    "onCommand:taproot.refreshNodes",
    "onCommand:taproot.copyAgentPrompt",
    "onCommand:taproot.startServer",
    "onCommand:taproot.stopServer",
    "onCommand:taproot.openNodeTerminal",
    "onCommand:taproot.copyNodeSsh"
  ],
  "contributes": {
    "commands": [
      {
        "command": "taproot.openDashboard",
        "title": "Open Dashboard",
        "category": "taproot-mcp"
      },
      {
        "command": "taproot.openConfig",
        "title": "Edit Config",
        "category": "taproot-mcp",
        "icon": "$(settings)"
      },
      {
        "command": "taproot.testConnections",
        "title": "Test Connections",
        "category": "taproot-mcp",
        "icon": "$(plug)"
      },
      {
        "command": "taproot.refreshNodes",
        "title": "Refresh Nodes",
        "category": "taproot-mcp",
        "icon": "$(refresh)"
      },
      {
        "command": "taproot.copyAgentPrompt",
        "title": "Copy Agent Prompt",
        "category": "taproot-mcp",
        "icon": "$(copy)"
      },
      {
        "command": "taproot.startServer",
        "title": "Start Local MCP Server",
        "category": "taproot-mcp",
        "icon": "$(debug-start)"
      },
      {
        "command": "taproot.stopServer",
        "title": "Stop Local MCP Server",
        "category": "taproot-mcp",
        "icon": "$(debug-stop)"
      },
      {
        "command": "taproot.openNodeTerminal",
        "title": "Open SSH Terminal",
        "category": "taproot-mcp",
        "icon": "$(terminal)"
      },
      {
        "command": "taproot.copyNodeSsh",
        "title": "Copy SSH Command",
        "category": "taproot-mcp",
        "icon": "$(copy)"
      }
    ],
    "icons": {
      "taproot-root": {
        "description": "Taproot root icon",
        "default": {
          "fontPath": "./media/taproot-icons.woff",
          "fontCharacter": "\\F101"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "taproot",
          "title": "taproot-mcp",
          "icon": "media/taproot.svg"
        }
      ]
    },
    "views": {
      "taproot": [
        {
          "id": "taproot.nodes",
          "name": "Nodes"
        }
      ]
    },
    "configuration": {
      "title": "taproot-mcp",
      "properties": {
        "taproot.configPath": {
          "type": "string",
          "default": "",
          "description": "Path to nodes.yaml. Empty uses ~/.config/taproot/nodes.yaml."
        },
        "taproot.taprootMcpCommand": {
          "type": "string",
          "default": "taproot-mcp",
          "description": "Command used to run taproot-mcp for validation, connection checks, and local server startup."
        },
        "taproot.statusPollIntervalSeconds": {
          "type": "number",
          "default": 60,
          "minimum": 0,
          "description": "Interval for background node status polling in seconds. Set to 0 to disable polling."
        },
        "taproot.httpHost": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "Host used when the extension starts the local Taproot HTTP MCP server."
        },
        "taproot.httpPort": {
          "type": "number",
          "default": 8765,
          "minimum": 1,
          "maximum": 65535,
          "description": "Port used when the extension starts the local Taproot HTTP MCP server."
        }
      }
    },
    "menus": {
      "commandPalette": [
        {
          "command": "taproot.openDashboard"
        },
        {
          "command": "taproot.openConfig"
        },
        {
          "command": "taproot.testConnections"
        },
        {
          "command": "taproot.refreshNodes"
        },
        {
          "command": "taproot.copyAgentPrompt"
        },
        {
          "command": "taproot.startServer"
        },
        {
          "command": "taproot.stopServer"
        }
      ],
      "view/title": [
        {
          "command": "taproot.copyAgentPrompt",
          "when": "view == taproot.nodes",
          "group": "navigation@1"
        },
        {
          "command": "taproot.startServer",
          "when": "view == taproot.nodes && taproot.serverStatusKnown && !taproot.serverRunning",
          "group": "navigation@2"
        },
        {
          "command": "taproot.stopServer",
          "when": "view == taproot.nodes && taproot.serverStatusKnown && taproot.serverRunning",
          "group": "navigation@2"
        },
        {
          "command": "taproot.openConfig",
          "when": "view == taproot.nodes",
          "group": "navigation@3"
        },
        {
          "command": "taproot.refreshNodes",
          "when": "view == taproot.nodes",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "taproot.openNodeTerminal",
          "when": "view == taproot.nodes && viewItem == taprootNode",
          "group": "inline@1"
        },
        {
          "command": "taproot.copyNodeSsh",
          "when": "view == taproot.nodes && viewItem == taprootNode",
          "group": "inline@2"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node --test out/test/*.test.js",
    "test:vscode": "npm run compile && node test/vscode-smoke/run.js",
    "package:vsix": "npm run compile && npm exec -- vsce package --dependencies && npm run verify:vsix",
    "verify:vsix": "node test/verify-vsix.js",
    "vscode:prepublish": "npm run compile"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.38",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^20.14.8",
    "@types/vscode": "^1.90.0",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "3.9.2",
    "jsdom": "^29.1.1",
    "typescript": "^5.5.4"
  }
}
